# Database
DATABASE_URL="postgresql://wise_user:wise_dev_password_2026@localhost:5432/wise_platform"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="generate-a-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="wise_search_key_2026"

# MinIO (S3-compatible file storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="wise_minio_user"
MINIO_SECRET_KEY="wise_minio_password_2026"
MINIO_BUCKET="wise-platform"
MINIO_USE_SSL=false

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@wisemarket.com.pk"

# API
API_PORT=4000
API_BASE_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Pakistan Defaults
